rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // In this Architecture, the database is strictly accessed server-side by the Node.js / Vercel Express API.
    // The client UI connects only via standard secure /api REST routes where complete role, status, 
    // and access authorization is fully enforced by the server backend. 
    // Therefore, the Firestore collections are open to the server's unauthenticated client-SDK sync queries.

    // Users Collection rules
    match /users/{userId} {
      allow read, write: if true;
    }

    // Passwords Collection rules
    match /passwords/{userId} {
      allow read, write: if true;
    }

    // Applications Collection rules
    match /applications/{employeeId} {
      allow read, write: if true;
    }

    // Documents Collection rules
    match /documents/{docId} {
      allow read, write: if true;
    }

    // Tests Collection rules
    match /tests/{testId} {
      allow read, write: if true;
    }

    // AssignedTests Collection rules
    match /assignedTests/{assignedId} {
      allow read, write: if true;
    }

    // Checklists Collection rules
    match /checklists/{checklistId} {
      allow read, write: if true;
    }

    // ActivityLogs Collection rules
    match /activityLogs/{logId} {
      allow read, write: if true;
    }

    // Emails Collection rules
    match /emails/{emailId} {
      allow read, write: if true;
    }

    // Notifications Collection rules
    match /notifications/{notifId} {
      allow read, write: if true;
    }

    // Annotations Collection rules
    match /annotations/{annotationId} {
      allow read, write: if true;
    }

    // Messages Collection rules
    match /messages/{messageId} {
      allow read, write: if true;
    }

    // Tasks Collection rules
    match /tasks/{taskId} {
      allow read, write: if true;
    }

    // TaskSubmissions Collection rules
    match /taskSubmissions/{submissionId} {
      allow read, write: if true;
    }

    // Attendance Collection rules
    match /attendance/{attendanceId} {
      allow read, write: if true;
    }

    // Leaves Collection rules
    match /leaves/{leaveId} {
      allow read, write: if true;
    }
  }
}
